generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  approved
  rejected
}

enum UserRole {
  umat
  admin
}

enum FeedbackType {
  suggestion
  violation_report
}

// Sequential, forward-only inbox states (Baru → Dibaca → Diproses → Selesai).
enum FeedbackStatus {
  new
  read
  in_progress
  done
}

// Categories apply to suggestions only (per design doc).
enum SuggestionCategory {
  fasilitas_ruangan
  prosedur_booking
  kegiatan_paroki
  lainnya
}

model Room {
  id         String    @id @default(cuid())
  name       String
  capacity   Int
  facilities String    @default("") // freetext, e.g. "Proyektor, AC, sound system"
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  bookings Booking[]
  feedback Feedback[]

  @@map("rooms")
}

// One table for everyone; `role` gates umat vs admin access.
model User {
  id           String   @id @default(cuid())
  nama         String
  email        String   @unique
  noWhatsapp   String
  lingkungan   String   // e.g. "Wilayah II - Lingkungan St. Maria"
  passwordHash String
  role         UserRole @default(umat)
  createdAt    DateTime @default(now())

  bookings        Booking[]  @relation("Pemohon")
  decidedBookings Booking[]  @relation("DecidedBy")
  feedbacks       Feedback[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// One row per browser/device a umat has granted notification permission on.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model Booking {
  id       String @id @default(cuid())
  roomId   String
  room     Room   @relation(fields: [roomId], references: [id])

  pemohonId String
  pemohon   User   @relation("Pemohon", fields: [pemohonId], references: [id])

  // Snapshot of contact shown on the form (prefilled from account, editable).
  requesterName    String
  requesterContact String

  timPelayanan       String? // "Tim Pelayanan / Kelompok", e.g. "Legio Maria"
  purpose            String  // tujuan_peminjaman
  peminjamanBerkala  Boolean @default(false)
  suratPermohonanUrl String? // uploaded PDF (relative /uploads path)

  startTime DateTime @db.Timestamptz(3)
  endTime   DateTime @db.Timestamptz(3)

  status      BookingStatus @default(pending)
  adminNote   String?
  decidedById String?
  decidedBy   User?         @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedback Feedback[]

  @@index([roomId, startTime, endTime])
  @@index([status])
  @@index([pemohonId])
  @@map("bookings")
}

model Feedback {
  id   String       @id @default(cuid())
  type FeedbackType

  category SuggestionCategory? // suggestions only
  roomId   String? // violation reports reference a room
  room     Room?               @relation(fields: [roomId], references: [id])

  relatedBookingId String?
  relatedBooking   Booking? @relation(fields: [relatedBookingId], references: [id])

  senderId     String?
  sender       User?   @relation(fields: [senderId], references: [id])
  reporterName String?
  email        String? // reply target
  message      String

  status     FeedbackStatus @default(new)
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@map("feedback")
}
