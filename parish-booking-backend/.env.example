# Postgres connection string from Neon/Supabase/Render
DATABASE_URL="postgresql://user:password@host:5432/parish_booking?schema=public"

# Any long random string — used to sign admin JWTs
JWT_SECRET="replace-with-a-long-random-string"

PORT=3000

# Comma-separated browser origins allowed to call the API (no trailing slash).
# Leave unset locally to default to the Vite dev server (localhost:5173).
# In production set this to your frontend domain(s), e.g.
# CORS_ORIGINS="https://parish-booking.vercel.app"
CORS_ORIGINS=""

# Where uploaded Surat Permohonan PDFs are stored. On Railway this MUST point at
# a mounted volume (e.g. /data/uploads) or files are lost on every redeploy.
UPLOADS_DIR=""

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:sekretariat@purbayan-paroki.org"

# Transactional email — while unset, admin replies are logged instead of sent.
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM="sekretariat@purbayan-paroki.org"
